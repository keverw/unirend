{
  "name": "unirend/php-static-server",
  "description": "PHP companion to StaticWebServer — deploy Unirend SSG output on shared hosting with clean URLs, proper 404/500 status codes, range requests, and custom routes.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "static-site",
    "ssg",
    "unirend",
    "shared-hosting",
    "static-server"
  ],
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Unirend\\StaticServer\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Unirend\\StaticServer\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
